<%- include('partials/header') %>

<!-- Page Header -->
<section class="page-header">
  <div class="container text-center text-white">
    <h1 class="display-5 fw-bold">Our <span class="text-warning">Rooms</span></h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/" class="text-warning text-decoration-none">Home</a></li>
        <li class="breadcrumb-item text-light active">Rooms</li>
      </ol>
    </nav>
  </div>
</section>

<!-- Filter -->
<section class="py-4 bg-light">
  <div class="container">
    <div class="d-flex justify-content-center flex-wrap gap-2">
      <a href="/rooms" class="btn <%= selectedCategory === 'all' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill px-4">All Rooms</a>
      <a href="/rooms?category=Economy" class="btn <%= selectedCategory === 'Economy' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill px-4">Economy</a>
      <a href="/rooms?category=Standard" class="btn <%= selectedCategory === 'Standard' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill px-4">Standard</a>
      <a href="/rooms?category=Deluxe" class="btn <%= selectedCategory === 'Deluxe' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill px-4">Deluxe</a>
      <a href="/rooms?category=Executive" class="btn <%= selectedCategory === 'Executive' ? 'btn-warning' : 'btn-outline-warning' %> rounded-pill px-4">Executive</a>
    </div>
  </div>
</section>

<!-- Rooms Grid -->
<section class="py-5">
  <div class="container">
    <% if (rooms.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-emoji-frown display-1 text-muted"></i>
        <h3 class="mt-3 text-muted">No rooms available</h3>
        <p class="text-muted">Please check back later or try a different category.</p>
        <a href="/rooms" class="btn btn-warning rounded-pill px-4">View All Rooms</a>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% rooms.forEach(room => { %>
          <div class="col-lg-4 col-md-6">
            <div class="card room-card border-0 shadow rounded-4 overflow-hidden h-100">
              <div class="room-card-img position-relative" style="height:220px;overflow:hidden">
                <% if (room.image) { %>
                  <img src="<%= room.image %>" alt="<%= room.name %>" data-fallback style="width:100%;height:100%;object-fit:cover">
                  <div style="display:none;height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);align-items:center;justify-content:center">
                    <div class="text-center text-white">
                      <i class="bi bi-door-open display-3"></i>
                      <p class="mt-2 mb-0 fw-bold fs-5"><%= room.category %> <%= room.type %></p>
                    </div>
                  </div>
                <% } else { %>
                  <div style="height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center">
                    <div class="text-center text-white">
                      <i class="bi bi-door-open display-3"></i>
                      <p class="mt-2 mb-0 fw-bold fs-5"><%= room.category %> <%= room.type %></p>
                    </div>
                  </div>
                <% } %>
                <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark fs-6 shadow">₹<%= room.price.toLocaleString('en-IN') %>/night</span>
              </div>
              <div class="card-body p-4">
                <h5 class="card-title fw-bold mb-2"><%= room.name %></h5>
                <p class="text-muted small mb-3"><%= room.description %></p>
                <div class="d-flex flex-wrap gap-1 mb-3">
                  <% room.amenities.split(',').forEach(amenity => { %>
                    <span class="badge bg-light text-dark border small"><i class="bi bi-check-lg text-success me-1"></i><%= amenity.trim() %></span>
                  <% }); %>
                </div>
                <div class="d-grid gap-2 d-md-flex">
                  <a href="/rooms/<%= room.id %>" class="btn btn-outline-warning flex-fill rounded-pill"><i class="bi bi-eye me-1"></i>View Details</a>
                  <a href="/booking/<%= room.id %>" class="btn btn-warning flex-fill rounded-pill"><i class="bi bi-calendar-check me-1"></i>Book Now</a>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<!-- Extra Person Charges -->
<section class="py-4 bg-light">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body text-center p-4">
            <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-warning me-2"></i>Additional Charges</h5>
            <p class="mb-1"><strong>Extra Person (A/C):</strong> <span class="text-success fw-bold">₹500/-</span> per night</p>
            <p class="mb-0"><strong>Extra Person (Non A/C):</strong> <span class="text-success fw-bold">₹400/-</span> per night</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
