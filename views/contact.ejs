<%- include('partials/header') %>

<!-- Page Header -->
<section class="page-header">
  <div class="container text-center text-white">
    <h1 class="display-5 fw-bold">Contact <span class="text-warning">Us</span></h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/" class="text-warning text-decoration-none">Home</a></li>
        <li class="breadcrumb-item text-light active">Contact</li>
      </ol>
    </nav>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <!-- Contact Info -->
      <div class="col-lg-5">
        <h3 class="fw-bold mb-4">Get in <span class="text-warning">Touch</span></h3>
        <p class="text-muted mb-4">Have questions or need assistance? We're here to help! Reach out to us through any of the following channels.</p>

        <div class="card border-0 shadow-sm rounded-4 mb-3">
          <div class="card-body p-4">
            <div class="d-flex align-items-start">
              <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width:50px;height:50px">
                <i class="bi bi-geo-alt-fill text-warning fs-4"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1">Address</h6>
                <p class="text-muted mb-0">276, Shaheed Bhagat Singh Road, Near GPO, Fort, Mumbai-400001</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-3">
          <div class="card-body p-4">
            <div class="d-flex align-items-start">
              <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width:50px;height:50px">
                <i class="bi bi-telephone-fill text-warning fs-4"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1">Phone</h6>
                <p class="text-muted mb-1">Tel: +91-22-3022 7886</p>
                <p class="text-muted mb-0">Cell: +91-82864 70877</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 mb-3">
          <div class="card-body p-4">
            <div class="d-flex align-items-start">
              <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width:50px;height:50px">
                <i class="bi bi-envelope-fill text-warning fs-4"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1">Email</h6>
                <p class="text-muted mb-1">info@hoteloasisindia.in</p>
                <p class="text-muted mb-0">hoteloasismumbai@gmail.com</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
          <div class="card-body p-4">
            <div class="d-flex align-items-start">
              <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width:50px;height:50px">
                <i class="bi bi-whatsapp text-success fs-4"></i>
              </div>
              <div>
                <h6 class="fw-bold mb-1">WhatsApp</h6>
                <p class="text-muted mb-2">Chat with us directly</p>
                <a href="https://wa.me/918286470877?text=Hello%2C%20I%20would%20like%20to%20inquire%20about%20Hotel%20Oasis" class="btn btn-success btn-sm rounded-pill px-3" target="_blank" rel="noopener noreferrer">
                  <i class="bi bi-whatsapp me-1"></i>Open WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="col-lg-7">
        <div class="card border-0 shadow rounded-4">
          <div class="card-body p-5">
            <h3 class="fw-bold mb-4">Send us a <span class="text-warning">Message</span></h3>

            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
              <div class="alert alert-danger rounded-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong>Please fix the following errors:</strong>
                <ul class="mb-0 mt-2">
                  <% errors.forEach(error => { %>
                    <li><%= error.msg %></li>
                  <% }); %>
                </ul>
              </div>
            <% } %>

            <form action="/contact" method="POST" novalidate>
              <div class="row g-3">
                <div class="col-md-6">
                  <label for="name" class="form-label fw-bold">Full Name <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text bg-warning border-0"><i class="bi bi-person-fill text-dark"></i></span>
                    <input type="text" class="form-control" id="name" name="name" placeholder="Your full name" required value="<%= typeof formData !== 'undefined' && formData.name ? formData.name : '' %>">
                  </div>
                </div>
                <div class="col-md-6">
                  <label for="email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text bg-warning border-0"><i class="bi bi-envelope-fill text-dark"></i></span>
                    <input type="email" class="form-control" id="email" name="email" placeholder="your@email.com" required value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>">
                  </div>
                </div>
                <div class="col-md-6">
                  <label for="phone" class="form-label fw-bold">Phone <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text bg-warning border-0"><i class="bi bi-phone-fill text-dark"></i></span>
                    <select class="form-select" name="country_code" id="country_code" style="max-width:120px">
                      <option value="+91" selected>+91 🇮🇳</option>
                      <option value="+1">+1 🇺🇸</option>
                      <option value="+44">+44 🇬🇧</option>
                      <option value="+971">+971 🇦🇪</option>
                      <option value="+966">+966 🇸🇦</option>
                      <option value="+61">+61 🇦🇺</option>
                      <option value="+49">+49 🇩🇪</option>
                      <option value="+33">+33 🇫🇷</option>
                      <option value="+81">+81 🇯🇵</option>
                      <option value="+86">+86 🇨🇳</option>
                      <option value="+7">+7 🇷🇺</option>
                      <option value="+39">+39 🇮🇹</option>
                      <option value="+34">+34 🇪🇸</option>
                      <option value="+55">+55 🇧🇷</option>
                      <option value="+27">+27 🇿🇦</option>
                      <option value="+82">+82 🇰🇷</option>
                      <option value="+65">+65 🇸🇬</option>
                      <option value="+60">+60 🇲🇾</option>
                      <option value="+66">+66 🇹🇭</option>
                      <option value="+62">+62 🇮🇩</option>
                      <option value="+94">+94 🇱🇰</option>
                      <option value="+977">+977 🇳🇵</option>
                      <option value="+880">+880 🇧🇩</option>
                      <option value="+92">+92 🇵🇰</option>
                      <option value="+254">+254 🇰🇪</option>
                    </select>
                    <input type="tel" class="form-control" id="phone" name="phone" placeholder="Phone number" required pattern="[0-9]{7,15}" maxlength="15" title="Enter phone number (7-15 digits)" value="<%= typeof formData !== 'undefined' && formData.phone ? formData.phone : '' %>">
                  </div>
                  <small class="text-muted">Select country code and enter phone number</small>
                </div>
                <div class="col-md-6">
                  <label for="subject" class="form-label fw-bold">Subject <span class="text-danger">*</span></label>
                  <div class="input-group">
                    <span class="input-group-text bg-warning border-0"><i class="bi bi-chat-dots-fill text-dark"></i></span>
                    <input type="text" class="form-control" id="subject" name="subject" placeholder="Subject" required value="<%= typeof formData !== 'undefined' && formData.subject ? formData.subject : '' %>">
                  </div>
                </div>
                <div class="col-12">
                  <label for="message" class="form-label fw-bold">Message <span class="text-danger">*</span></label>
                  <textarea class="form-control" id="message" name="message" rows="5" placeholder="Write your message here..." required><%= typeof formData !== 'undefined' && formData.message ? formData.message : '' %></textarea>
                </div>
                <div class="col-12">
                  <button type="submit" class="btn btn-warning btn-lg px-5 rounded-pill shadow">
                    <i class="bi bi-send-fill me-2"></i>Send Message
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
