<%- include('partials/header') %>

<!-- Page Header -->
<section class="page-header">
  <div class="container text-center text-white">
    <h1 class="display-5 fw-bold"><%= room.name %></h1>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb justify-content-center">
        <li class="breadcrumb-item"><a href="/" class="text-warning text-decoration-none">Home</a></li>
        <li class="breadcrumb-item"><a href="/rooms" class="text-warning text-decoration-none">Rooms</a></li>
        <li class="breadcrumb-item text-light active"><%= room.name %></li>
      </ol>
    </nav>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <div class="col-lg-7">
        <div class="room-detail-img rounded-4 shadow-lg" style="height:400px;overflow:hidden">
          <% if (room.image) { %>
            <img src="<%= room.image %>" alt="<%= room.name %>" data-fallback style="width:100%;height:100%;object-fit:cover">
            <div style="display:none;height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);align-items:center;justify-content:center">
              <div class="text-center text-white">
                <i class="bi bi-door-open display-1"></i>
                <h3 class="mt-3"><%= room.category %> <%= room.type %></h3>
              </div>
            </div>
          <% } else { %>
            <div style="height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center">
              <div class="text-center text-white">
                <i class="bi bi-door-open display-1"></i>
                <h3 class="mt-3"><%= room.category %> <%= room.type %></h3>
              </div>
            </div>
          <% } %>
        </div>
      </div>
      <div class="col-lg-5">
        <span class="badge bg-warning text-dark fs-6 mb-3 px-3 py-2 rounded-pill"><%= room.category %> - <%= room.type %></span>
        <h2 class="fw-bold mb-3"><%= room.name %></h2>
        <p class="text-muted fs-5"><%= room.description %></p>
        <div class="price-box bg-light rounded-4 p-4 mb-4">
          <div class="d-flex align-items-baseline">
            <span class="display-5 fw-bold text-warning">₹<%= room.price.toLocaleString('en-IN') %></span>
            <span class="text-muted ms-2 fs-5">/ per night</span>
          </div>
          <p class="text-muted mb-0 mt-1">Inclusive of all taxes</p>
        </div>

        <h5 class="fw-bold mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Amenities</h5>
        <div class="row g-2 mb-4">
          <% room.amenities.split(',').forEach(amenity => { %>
            <div class="col-6">
              <div class="d-flex align-items-center p-2 bg-light rounded-3">
                <i class="bi bi-check-circle-fill text-success me-2"></i>
                <span><%= amenity.trim() %></span>
              </div>
            </div>
          <% }); %>
        </div>

        <a href="/booking/<%= room.id %>" class="btn btn-warning btn-lg w-100 rounded-pill shadow">
          <i class="bi bi-calendar-check me-2"></i>Book This Room
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
