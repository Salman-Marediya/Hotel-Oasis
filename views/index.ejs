<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero-section">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-8 mx-auto text-center text-white">
        <h5 class="text-warning fw-light mb-3 animate-fade-in">★★★★★ PREMIUM HOTEL</h5>
        <h1 class="display-3 fw-bold mb-4 animate-fade-in">Welcome to<br><span class="text-warning">Hotel Oasis</span></h1>
        <p class="lead mb-4 animate-fade-in">Ideally located in the heart of Mumbai City, commercial capital of India. A perfect place for relaxation in luxury since 1985.</p>
        <div class="animate-fade-in">
          <a href="/rooms" class="btn btn-warning btn-lg px-5 me-3 rounded-pill shadow"><i class="bi bi-door-open me-2"></i>View Rooms</a>
          <a href="/contact" class="btn btn-outline-light btn-lg px-5 rounded-pill"><i class="bi bi-telephone me-2"></i>Contact Us</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-wifi fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Free WiFi</h6>
          <p class="text-muted small mb-0">High-speed internet in all rooms</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-snow fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Air Conditioned</h6>
          <p class="text-muted small mb-0">32 A/C rooms available</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-tv fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">Satellite TV</h6>
          <p class="text-muted small mb-0">Colour TV with satellite channels</p>
        </div>
      </div>
      <div class="col-md-3 col-6">
        <div class="feature-card p-4 bg-white rounded-4 shadow-sm h-100">
          <div class="feature-icon bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:70px;height:70px">
            <i class="bi bi-clock fs-2 text-warning"></i>
          </div>
          <h6 class="fw-bold">24/7 Service</h6>
          <p class="text-muted small mb-0">Round the clock assistance</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- About Preview -->
<section class="py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="position-relative">
          <div class="about-img-placeholder rounded-4 shadow-lg" style="height:400px;overflow:hidden;background:linear-gradient(135deg,#c8a96e 0%,#8B6914 100%);display:flex;align-items:center;justify-content:center">
            <img src="/images/reception.jpg" alt="Hotel Oasis Reception" style="width:100%;height:100%;object-fit:cover" class="fallback-img">
            <div class="fallback-content text-center text-white" style="position:absolute">
              <i class="bi bi-building display-1 mb-3"></i>
              <h3>Since 1985</h3>
              <p>Over 38 Years of Excellence</p>
            </div>
          </div>
          <div class="position-absolute bottom-0 end-0 bg-warning text-dark p-3 rounded-3 shadow m-3">
            <h4 class="mb-0 fw-bold">32</h4>
            <small>Luxury Rooms</small>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <h6 class="text-warning fw-bold text-uppercase">About Our Hotel</h6>
        <h2 class="display-6 fw-bold mb-4">Experience Luxury & Comfort at <span class="text-warning">Hotel Oasis</span></h2>
        <p class="text-muted">Hotel Oasis founded in 1985, ideally located in the heart of Mumbai City, commercial capital of India. You'll find everything more than your expectations.</p>
        <p class="text-muted">All rooms are well designed with vibrant colours and furniture. A perfect place for relaxation in luxury. Hotel Oasis has evolved from time to time in its effort to cater to the growing needs of global and domestic travellers.</p>
        <div class="row g-3 mt-3 mb-4">
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Free WiFi Internet</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Satellite Channels</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Intercom Facility</span>
            </div>
          </div>
          <div class="col-6">
            <div class="d-flex align-items-center">
              <i class="bi bi-check-circle-fill text-warning me-2 fs-5"></i>
              <span>Affordable Prices</span>
            </div>
          </div>
        </div>
        <a href="/about" class="btn btn-warning px-4 rounded-pill shadow-sm"><i class="bi bi-arrow-right me-2"></i>Learn More</a>
      </div>
    </div>
  </div>
</section>

<!-- Room Preview Section -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-5">
      <h6 class="text-warning fw-bold text-uppercase">Accommodation</h6>
      <h2 class="display-6 fw-bold">Our <span class="text-warning">Rooms & Suites</span></h2>
      <p class="text-muted mx-auto" style="max-width:600px">Choose from our range of well-designed rooms with vibrant colours and modern amenities</p>
    </div>
    <div class="row g-4">
      <% rooms.forEach(room => { %>
        <div class="col-lg-3 col-md-6">
          <div class="card room-card border-0 shadow-sm rounded-4 overflow-hidden h-100">
            <div class="room-card-img" style="height:200px;overflow:hidden">
              <% if (room.image) { %>
                <img src="<%= room.image %>" alt="<%= room.name %>" data-fallback style="width:100%;height:100%;object-fit:cover">
                <div style="display:none;height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);align-items:center;justify-content:center">
                  <div class="text-center text-white">
                    <i class="bi bi-door-open display-4"></i>
                    <p class="mt-2 mb-0 fw-bold"><%= room.category %></p>
                  </div>
                </div>
              <% } else { %>
                <div style="height:100%;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center">
                  <div class="text-center text-white">
                    <i class="bi bi-door-open display-4"></i>
                    <p class="mt-2 mb-0 fw-bold"><%= room.category %></p>
                  </div>
                </div>
              <% } %>
            </div>
            <div class="card-body p-4">
              <h5 class="card-title fw-bold"><%= room.name %></h5>
              <p class="text-muted small mb-3"><%= room.description.substring(0, 80) %>...</p>
              <div class="d-flex flex-wrap gap-2 mb-3">
                <% room.amenities.split(',').slice(0, 3).forEach(amenity => { %>
                  <span class="badge bg-light text-dark border"><%= amenity.trim() %></span>
                <% }); %>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <div>
                  <span class="h5 text-warning fw-bold">₹<%= room.price.toLocaleString('en-IN') %></span>
                  <small class="text-muted">/night</small>
                </div>
                <a href="/rooms/<%= room.id %>" class="btn btn-outline-warning btn-sm rounded-pill px-3">View Details</a>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
    <div class="text-center mt-5">
      <a href="/rooms" class="btn btn-warning btn-lg px-5 rounded-pill shadow"><i class="bi bi-grid me-2"></i>View All Rooms</a>
    </div>
  </div>
</section>

<!-- Nearby Tourist Places -->
<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <h6 class="text-warning fw-bold text-uppercase">Explore Mumbai</h6>
      <h2 class="display-6 fw-bold">Nearby <span class="text-warning">Tourist Places</span></h2>
      <p class="text-muted mx-auto" style="max-width:600px">Hotel Oasis is surrounded by iconic landmarks and tourist attractions of Mumbai</p>
    </div>
    <div class="row g-4">
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/gateway-of-india.jpg" alt="Gateway of India" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-bank2 display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Gateway of India</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Apollo Bunder, Colaba — 2.5 km away</p>
            <p class="text-muted small">Built in 1924, this iconic arch monument overlooks the Arabian Sea. Constructed to commemorate the visit of King George V and Queen Mary, it is one of India's most photographed landmarks and a symbol of Mumbai.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/cst-mumbai.jpg" alt="Chhatrapati Shivaji Terminus" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-train-front display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Chhatrapati Shivaji Terminus</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Fort, Mumbai — 0.8 km away</p>
            <p class="text-muted small">A UNESCO World Heritage Site built in 1888, this historic railway station is an outstanding example of Victorian Gothic Revival architecture blended with traditional Indian elements. Formerly known as Victoria Terminus.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#4facfe 0%,#00f2fe 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/marine-drive.jpg" alt="Marine Drive" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-water display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Marine Drive</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Netaji Subhash Chandra Road — 3 km away</p>
            <p class="text-muted small">Known as the "Queen's Necklace" for its sparkling nighttime view, this 3.6 km long boulevard along the coast is a favourite promenade since the 1920s. Perfect for evening walks with stunning sunset views.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#43e97b 0%,#38f9d7 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/flora-fountain.jpg" alt="Flora Fountain" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-building display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Flora Fountain</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Hutatma Chowk, Fort — 0.5 km away</p>
            <p class="text-muted small">An ornamental fountain built in 1864 at the junction of five roads. Named after the Roman goddess of flowers, it is a heritage structure and a major landmark of the Fort business district of South Mumbai.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#fa709a 0%,#fee140 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/elephanta-caves.jpg" alt="Elephanta Caves" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-image display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Elephanta Caves</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Elephanta Island — Ferry from Gateway of India</p>
            <p class="text-muted small">A UNESCO World Heritage Site, these rock-cut cave temples dating back to the 5th–8th centuries feature magnificent sculptures dedicated to Lord Shiva. Accessible by a scenic one-hour ferry ride from the Gateway of India.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
          <div class="tourist-img-container" style="height:180px;overflow:hidden;background:linear-gradient(135deg,#a18cd1 0%,#fbc2eb 100%);display:flex;align-items:center;justify-content:center;position:relative">
            <img src="/images/csmvs-museum.jpg" alt="Chhatrapati Shivaji Maharaj Vastu Sangrahalaya" style="width:100%;height:100%;object-fit:cover;position:relative;z-index:1" class="fallback-img">
            <i class="bi bi-columns-gap display-3 text-white" style="position:absolute;z-index:0"></i>
          </div>
          <div class="card-body p-4">
            <h5 class="fw-bold">Chhatrapati Shivaji Maharaj Vastu Sangrahalaya</h5>
            <p class="text-muted small mb-2"><i class="bi bi-geo-alt text-warning me-1"></i>Kala Ghoda, Fort — 1.5 km away</p>
            <p class="text-muted small">Formerly the Prince of Wales Museum, established in 1922, this museum houses approximately 50,000 artefacts of ancient Indian history, art and natural history in a stunning Indo-Saracenic building.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials / CTA -->
<section class="py-5 bg-dark text-white">
  <div class="container text-center">
    <h6 class="text-warning fw-bold text-uppercase">Book Your Stay</h6>
    <h2 class="display-6 fw-bold mb-4">Ready for an <span class="text-warning">Unforgettable</span> Experience?</h2>
    <p class="lead text-secondary mb-4 mx-auto" style="max-width:600px">Hotel Oasis is surrounded with city attractions like famous hospitals, business and tourist places. Book now and enjoy superb ambience with attentive, efficient and personalized services.</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="/rooms" class="btn btn-warning btn-lg px-5 rounded-pill shadow"><i class="bi bi-calendar-check me-2"></i>Book Now</a>
      <a href="tel:+912230227886" class="btn btn-outline-light btn-lg px-5 rounded-pill"><i class="bi bi-telephone me-2"></i>Call Us</a>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
