<%- include('partials/header') %>

<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-6 text-center">
        <% if (booking) { %>
          <div class="card border-0 shadow rounded-4 p-5">
            <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mx-auto mb-4" style="width:100px;height:100px">
              <i class="bi bi-check-circle-fill text-success display-3"></i>
            </div>
            <h2 class="fw-bold text-success mb-3">Booking Has Been Sent!</h2>
            <p class="text-muted mb-4">Your reservation request has been received successfully. <strong>We will contact you shortly</strong> to confirm your booking. Thank you for choosing Hotel Oasis!</p>

            <div class="bg-light rounded-4 p-4 text-start">
              <h5 class="fw-bold mb-3"><i class="bi bi-receipt text-warning me-2"></i>Booking Summary</h5>
              <table class="table table-borderless mb-0">
                <tr>
                  <td class="text-muted">Booking ID:</td>
                  <td class="fw-bold">#<%= booking.id %></td>
                </tr>
                <tr>
                  <td class="text-muted">Room:</td>
                  <td class="fw-bold"><%= booking.room_name %></td>
                </tr>
                <tr>
                  <td class="text-muted">Guest:</td>
                  <td class="fw-bold"><%= booking.guest_name %></td>
                </tr>
                <tr>
                  <td class="text-muted">Check-in:</td>
                  <td class="fw-bold"><%= booking.check_in %></td>
                </tr>
                <tr>
                  <td class="text-muted">Check-out:</td>
                  <td class="fw-bold"><%= booking.check_out %></td>
                </tr>
                <tr>
                  <td class="text-muted">Duration:</td>
                  <td class="fw-bold"><%= booking.nights %> night(s)</td>
                </tr>
                <tr>
                  <td class="text-muted">Estimated Amount:</td>
                  <td class="fw-bold text-warning fs-5">₹<%= booking.total_amount.toLocaleString('en-IN') %></td>
                </tr>
              </table>
            </div>

            <div class="alert alert-info rounded-3 mt-4 text-start">
              <i class="bi bi-info-circle-fill me-2"></i>
              Our team will reach out to you via phone or email to confirm your reservation and discuss payment options.
            </div>

            <div class="mt-4">
              <a href="/" class="btn btn-warning px-4 rounded-pill me-2"><i class="bi bi-house me-1"></i>Back to Home</a>
              <a href="/rooms" class="btn btn-outline-warning px-4 rounded-pill"><i class="bi bi-door-open me-1"></i>View More Rooms</a>
            </div>
          </div>
        <% } else { %>
          <div class="card border-0 shadow rounded-4 p-5">
            <i class="bi bi-info-circle display-1 text-warning mb-3"></i>
            <h3 class="fw-bold">Booking Information</h3>
            <p class="text-muted">No booking details available. Please try booking again.</p>
            <a href="/rooms" class="btn btn-warning px-4 rounded-pill">Browse Rooms</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/layout-end') %>
